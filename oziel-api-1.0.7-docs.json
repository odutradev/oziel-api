											"if (pm.response.code === 200) {",
											"    var jsonData = pm.response.json();",
											"    if (jsonData.token) {",
											"        pm.environment.set(\"authorization\", jsonData.token);",
											"        console.log(\"Authorization token automatically updated in environment.\");",
											"    }",
											"}"
